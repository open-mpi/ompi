/*
 * Test intent:
 *   Define a window error-handler callback that validates the ABI
 *   window handle and error-code values received from Open MPI.  The
 *   body creates a real window so the callback path exercises the RMA
 *   object conversion layer.
 */
struct win_errhandler_state {
    MPI_Win win;
    int calls;
    int error_code;
    int failure_code;
};

static struct win_errhandler_state win_errhandler_state;

static void win_errhandler_callback(MPI_Win *win, int *error_code, ...)
{
    if (NULL == win) {
        win_errhandler_state.failure_code = 101;
    } else if (*win != win_errhandler_state.win) {
        win_errhandler_state.failure_code = 102;
    } else if (NULL == error_code) {
        win_errhandler_state.failure_code = 103;
    } else if (MPI_ERR_OTHER != *error_code) {
        win_errhandler_state.failure_code = 104;
    } else {
        win_errhandler_state.error_code = *error_code;
        ++win_errhandler_state.calls;
    }
}
