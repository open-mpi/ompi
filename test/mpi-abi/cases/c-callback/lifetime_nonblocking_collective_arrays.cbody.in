/*
 * Test intent:
 *   Exercise retained converted-array lifetime for a nonblocking
 *   collective.  MPI_Ialltoallw takes count, displacement, and datatype
 *   arrays that the standard ABI wrapper must convert before entering
 *   Open MPI.  After MPI_Ialltoallw returns, this probe overwrites the
 *   user-side arrays before MPI_Wait.  Completion must still use the
 *   originally supplied values; otherwise the ABI wrapper retained the
 *   wrong storage or released converted storage too early.
 */
int exit_code = 0;
int mpi_initialized = 0;
int *sendbuf = NULL;
int *recvbuf = NULL;
int *sendcounts = NULL;
int *recvcounts = NULL;
int *sdispls = NULL;
int *rdispls = NULL;
MPI_Datatype *sendtypes = NULL;
MPI_Datatype *recvtypes = NULL;
MPI_Request request = MPI_REQUEST_NULL;
int ret = MPI_Init(&argc, &argv);
if (MPI_SUCCESS != ret) {
    return 1;
}
mpi_initialized = 1;

int rank = -1;
int size = 0;
ret = MPI_Comm_rank(MPI_COMM_WORLD, &rank);
if (MPI_SUCCESS != ret) {
    exit_code = 2;
    goto cleanup;
}
ret = MPI_Comm_size(MPI_COMM_WORLD, &size);
if (MPI_SUCCESS != ret || size < 1) {
    exit_code = 3;
    goto cleanup;
}

sendbuf = calloc((size_t) size, sizeof(int));
recvbuf = calloc((size_t) size, sizeof(int));
sendcounts = calloc((size_t) size, sizeof(int));
recvcounts = calloc((size_t) size, sizeof(int));
sdispls = calloc((size_t) size, sizeof(int));
rdispls = calloc((size_t) size, sizeof(int));
sendtypes = calloc((size_t) size, sizeof(MPI_Datatype));
recvtypes = calloc((size_t) size, sizeof(MPI_Datatype));
if (NULL == sendbuf || NULL == recvbuf || NULL == sendcounts ||
    NULL == recvcounts || NULL == sdispls || NULL == rdispls ||
    NULL == sendtypes || NULL == recvtypes) {
    exit_code = 4;
    goto cleanup;
}

for (int i = 0; i < size; ++i) {
    sendbuf[i] = rank * 100 + i;
    recvbuf[i] = -1;
    sendcounts[i] = 1;
    recvcounts[i] = 1;
    sdispls[i] = i * (int) sizeof(int);
    rdispls[i] = i * (int) sizeof(int);
    sendtypes[i] = MPI_INT;
    recvtypes[i] = MPI_INT;
}

ret = MPI_Ialltoallw(sendbuf, sendcounts, sdispls, sendtypes,
                     recvbuf, recvcounts, rdispls, recvtypes,
                     MPI_COMM_WORLD, &request);
if (MPI_SUCCESS != ret || MPI_REQUEST_NULL == request) {
    exit_code = 5;
    goto cleanup;
}

for (int i = 0; i < size; ++i) {
    sendcounts[i] = 0;
    recvcounts[i] = 0;
    sdispls[i] = 0;
    rdispls[i] = 0;
    sendtypes[i] = MPI_DATATYPE_NULL;
    recvtypes[i] = MPI_DATATYPE_NULL;
}

ret = MPI_Wait(&request, MPI_STATUS_IGNORE);
if (MPI_SUCCESS != ret || MPI_REQUEST_NULL != request) {
    exit_code = 6;
    goto cleanup;
}

for (int peer = 0; peer < size; ++peer) {
    if (peer * 100 + rank != recvbuf[peer]) {
        exit_code = 7;
        goto cleanup;
    }
}

cleanup:
free(sendbuf);
free(recvbuf);
free(sendcounts);
free(recvcounts);
free(sdispls);
free(rdispls);
free(sendtypes);
free(recvtypes);

if (mpi_initialized) {
    ret = MPI_Finalize();
    if (MPI_SUCCESS != ret && 0 == exit_code) {
        exit_code = 8;
    }
}

if (0 != exit_code) {
    return exit_code;
}
if (MPI_SUCCESS != ret) {
    return 8;
}
