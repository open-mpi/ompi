/*
 * Test intent:
 *   Define a user reduction callback that validates datatype conversion,
 *   length conversion, and in/out buffer semantics through the ABI
 *   wrapper created by MPI_Op_create.  The body drives the callback via
 *   both MPI_Reduce_local and a real two-rank collective operation.
 */
struct user_op_state {
    int calls;
    int total_length;
    int failure_code;
};

static struct user_op_state user_op_state;

static void user_op_callback(void *invec, void *inoutvec, int *len,
                             MPI_Datatype *datatype)
{
    if (NULL == invec || NULL == inoutvec) {
        user_op_state.failure_code = 101;
        return;
    }
    if (NULL == len || *len < 1) {
        user_op_state.failure_code = 102;
        return;
    }
    if (NULL == datatype || MPI_INT != *datatype) {
        user_op_state.failure_code = 103;
        return;
    }

    int *in = (int *) invec;
    int *inout = (int *) inoutvec;
    for (int i = 0; i < *len; ++i) {
        inout[i] += in[i];
    }
    ++user_op_state.calls;
    user_op_state.total_length += *len;
}
