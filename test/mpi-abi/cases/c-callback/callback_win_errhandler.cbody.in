/*
 * Test intent:
 *   Exercise window errhandler callback creation, get/set/call,
 *   callback invocation, predefined-handler restoration, window free,
 *   and errhandler cleanup when RMA support is configured.
 */
int ret = MPI_Init(&argc, &argv);
if (MPI_SUCCESS != ret) {
    return 1;
}

int value = 0;
win_errhandler_state.win = MPI_WIN_NULL;
win_errhandler_state.calls = 0;
win_errhandler_state.error_code = MPI_SUCCESS;
win_errhandler_state.failure_code = 0;

ret = MPI_Win_create(&value, sizeof(value), sizeof(value), MPI_INFO_NULL,
                     MPI_COMM_WORLD, &win_errhandler_state.win);
if (MPI_SUCCESS != ret || MPI_WIN_NULL == win_errhandler_state.win) {
    return 2;
}

MPI_Errhandler errhandler = MPI_ERRHANDLER_NULL;
ret = MPI_Win_create_errhandler(win_errhandler_callback, &errhandler);
if (MPI_SUCCESS != ret || MPI_ERRHANDLER_NULL == errhandler) {
    return 3;
}

ret = MPI_Win_set_errhandler(win_errhandler_state.win, errhandler);
if (MPI_SUCCESS != ret) {
    return 4;
}

MPI_Errhandler queried = MPI_ERRHANDLER_NULL;
ret = MPI_Win_get_errhandler(win_errhandler_state.win, &queried);
if (MPI_SUCCESS != ret || MPI_ERRHANDLER_NULL == queried) {
    return 5;
}
ret = MPI_Errhandler_free(&queried);
if (MPI_SUCCESS != ret || MPI_ERRHANDLER_NULL != queried) {
    return 6;
}

ret = MPI_Win_call_errhandler(win_errhandler_state.win, MPI_ERR_OTHER);
if (MPI_SUCCESS != ret || 0 != win_errhandler_state.failure_code ||
    1 != win_errhandler_state.calls ||
    MPI_ERR_OTHER != win_errhandler_state.error_code) {
    return 7;
}

ret = MPI_Win_set_errhandler(win_errhandler_state.win, MPI_ERRORS_RETURN);
if (MPI_SUCCESS != ret) {
    return 8;
}
ret = MPI_Errhandler_free(&errhandler);
if (MPI_SUCCESS != ret || MPI_ERRHANDLER_NULL != errhandler ||
    0 != win_errhandler_state.failure_code ||
    1 != win_errhandler_state.calls) {
    return 9;
}

ret = MPI_Win_free(&win_errhandler_state.win);
if (MPI_SUCCESS != ret || MPI_WIN_NULL != win_errhandler_state.win) {
    return 10;
}

ret = MPI_Finalize();
if (MPI_SUCCESS != ret) {
    return 11;
}
