/*
 * Test intent:
 *   Define a communicator error-handler callback that validates the
 *   standard ABI communicator and error-code values passed back from
 *   Open MPI.  The body creates, installs, invokes, restores, and frees
 *   the errhandler so callback conversion and errhandler lifetime are
 *   both covered.
 */
struct comm_errhandler_state {
    MPI_Comm comm;
    int calls;
    int error_code;
    int failure_code;
};

static struct comm_errhandler_state comm_errhandler_state;

static void comm_errhandler_callback(MPI_Comm *comm, int *error_code, ...)
{
    if (NULL == comm) {
        comm_errhandler_state.failure_code = 101;
    } else if (*comm != comm_errhandler_state.comm) {
        comm_errhandler_state.failure_code = 102;
    } else if (NULL == error_code) {
        comm_errhandler_state.failure_code = 103;
    } else if (MPI_ERR_OTHER != *error_code) {
        comm_errhandler_state.failure_code = 104;
    } else {
        comm_errhandler_state.error_code = *error_code;
        ++comm_errhandler_state.calls;
    }
}
