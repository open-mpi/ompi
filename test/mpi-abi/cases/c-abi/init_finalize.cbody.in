    /*
     * Test intent:
     *   Exercise the smallest standard ABI MPI lifetime: initialize once,
     *   finalize once, and verify the calls return through libmpi_abi.
     */
    int ret = MPI_Init(&argc, &argv);
    if (MPI_SUCCESS != ret) {
        return 1;
    }
    ret = MPI_Finalize();
    if (MPI_SUCCESS != ret) {
        return 2;
    }
