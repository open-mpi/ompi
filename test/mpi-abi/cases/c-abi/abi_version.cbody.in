    /*
     * Test intent:
     *   Verify the installed standard ABI library reports the ABI version
     *   that the installed standard ABI header promised at compile time.
     */
    int major = -1;
    int minor = -1;
    int ret = MPI_Abi_get_version(&major, &minor);
    if (MPI_SUCCESS != ret) {
        return 1;
    }
    if (MPI_ABI_VERSION != major) {
        return 2;
    }
    if (MPI_ABI_SUBVERSION != minor) {
        return 3;
    }
