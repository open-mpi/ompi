help()
{
    printf "  show pids\n"
}

detailed_help()
{
    cat <<EOF
show pids
  Print all attached PIDs and the currently selected PIDs.
EOF
}

run()
{
    if [ 0 -eq $# ] || [ "help" = "$1" ] ; then
        detailed_help
        return 0
    fi

    case "$1" in
    pids)
        printf "Attached PIDs:%s\n" "$(printf " %s" $pids)"
        printf "Selected PIDs:%s\n" "$(printf " %s" $selected_pids)"
        ;;
    *)
        echo "Unsupported show argument: $1" >&2
        return 1
        ;;
    esac
}
