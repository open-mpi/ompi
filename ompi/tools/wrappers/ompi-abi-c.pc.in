# Note that the -I directory must be *before* the -L directory, or
# VPATH builds won't work correctly.

Name: @PACKAGE_NAME@
Description: Open MPI ABI C interface
Version: @PACKAGE_VERSION@
URL: https://www.open-mpi.org/
#
prefix=@prefix@
exec_prefix=@exec_prefix@
includedir=@includedir@/standard_abi
libdir=@libdir@
#
# Note that -lopen-pal is NOT included in the libraries list because
# it's an internal/private library
#
Libs: -L${libdir} -Wl,-rpath,${libdir} -lmpi_abi
Libs.private: @WRAPPER_EXTRA_LIBS@
#
Cflags: -I${includedir} @WRAPPER_EXTRA_CPPFLAGS@ @WRAPPER_EXTRA_CFLAGS@

