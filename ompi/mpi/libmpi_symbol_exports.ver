# Version script for GNU ld to re-export MPI predefined symbols from libopen_mpi
#
# This script makes libmpi.so re-export the 138 predefined MPI symbols
# (communicators, datatypes, operations, etc.) that moved from libmpi to
# libopen_mpi in Open MPI v6.0, ensuring backward compatibility with
# v5.x applications that link with -lmpi.
#
# See: https://github.com/open-mpi/ompi/issues/XXXXX

OMPI_6.0 {
    global: *;
};
