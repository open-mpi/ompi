/*
 * This template generates the F08 binding wrapper for MPI_Abi_get_fortran_booleans.
 *
 * LOGICAL_PTR_OUT type: This special type is used because the C implementation
 * needs to write directly to the bit pattern of the Fortran LOGICAL variables,
 * not integer representations. The LOGICAL_PTR_OUT type generates code that:
 * 1. Creates a LOGICAL temporary variable in Fortran
 * 2. Passes its address (via C_LOC) as a void* to this C wrapper
 * 3. The C wrapper passes that void* unchanged to the inner C implementation
 * 4. After the call, copies the temporary back to the actual output parameter
 *
 * Equivalence with mpif-h bindings:
 * The bindings generator handles LOGICALs using integers when interfacing to the
 * C wrapper functions in use-mpi-f08/base/api_f08_generated.c (see the generated
 * Fortran code in use-mpi-f08/api_f08_generated.f90). Despite the different
 * approaches, both mpif-h and mpi_f08 layers are equivalent and both call the
 * internal ompi_abi_get_fortran_booleans function:
 *
 * - mpif-h: Uses Fortran pass-by-reference to pass pointers to logical_true and
 *   logical_false arguments directly through to the internal C function.
 *
 * - mpi_f08: Uses C_LOC from ISO_C_BINDING to pass addresses of temporary LOGICAL
 *   variables in the generated Fortran binding code to this C wrapper, which then
 *   passes them unchanged as void* pointers to the internal C function. Upon
 *   return from ompi_abi_get_fortran_booleans_wrapper_f08, the values in these
 *   temporary variables are copied into the actual logical_true and logical_false
 *   output arguments passed to MPI_Abi_get_fortran_booleans_f08.
 *
 * Both approaches preserve the exact bit patterns of Fortran LOGICAL values as
 * required by the MPI ABI specification.
 */

PROTOTYPE VOID abi_get_fortran_booleans(INT logical_size, LOGICAL_PTR_OUT logical_true,
                                        LOGICAL_PTR_OUT logical_false,
                                        LOGICAL_OUT is_set)
{
    int c_ierr, c_is_set;

    /* c_logical_true and c_logical_false are void* pointers to LOGICAL temporaries.
     * They are passed unchanged to the inner C implementation which writes the
     * actual LOGICAL bit patterns directly. */
    c_ierr = @INNER_CALL@(OMPI_FINT_2_INT(*logical_size),
                          c_logical_true,
                          c_logical_false,
                          &c_is_set);
    if (NULL != ierr) *ierr = OMPI_INT_2_FINT(c_ierr);

    if (MPI_SUCCESS == c_ierr) {
        *is_set = OMPI_INT_2_FINT(c_is_set);
    }
}


