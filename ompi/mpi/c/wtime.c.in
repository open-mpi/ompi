#include "ompi_config.h"

#include "ompi/mpi/c/bindings.h"
#include "ompi/runtime/mpiruntime.h"
#include "ompi/runtime/ompi_spc.h"

PROTOTYPE DOUBLE wtime()
{
    SPC_RECORD(OMPI_SPC_WTIME, 1);

    return ompi_wtime();
}
